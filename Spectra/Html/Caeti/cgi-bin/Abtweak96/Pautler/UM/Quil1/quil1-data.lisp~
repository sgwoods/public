(def-rule-1
  :er31
  '((_is-desired (NOT (NOT ?event))) IMPLIED-BY (_is-desired ?event)) )

(def-rule-1
  :er32
  '((_has-result_ ?event1 (NOT (NOT ?event2))) IMPLIED-BY
    (_has-result_ ?event1 ?event2) ))

(def-rule-1 ;not yet needed, but added for completeness
  :er33
  '((_enables_ ?event1 (NOT (NOT ?event2))) IMPLIED-BY
    (_enables_ ?event1 ?event2) ))

(def-rule-1 ;not yet needed, but added for completeness
  :er34
  '((_has-result_ (NOT (NOT ?event1)) ?event2) IMPLIED-BY
    (_has-result_ ?event1 ?event2) ))

(def-rule-1 ;not yet needed, but added for completeness
  :er35
  '((_enables_ (NOT (NOT ?event1)) ?event2) IMPLIED-BY
    (_enables_ ?event1 ?event2) ))


