;; general use routines

(defun random-element1 (list)
   "Tw-routines/general.lsp
    select a random element from list"
   (declare (type list list))
   (ith (random (length list)) list) )

(defun my-delete (e list)
  "Tw-routines/general.lsp  old
   remove a list or atom from a list"
  (declare
          (type atom e)
          (type list list)
   )
  (if (eq (car list) nil)
      nil
      (if (equal e (car list))   ; e found in list      
          (my-delete e (cdr list)) 
          (append (list (car list))
                  (my-delete e (cdr list))))))

(defun memb (e list)
  "Tw-routines/general.lsp
   acts like member, but is general over list structures"
  (declare
          (type atom e)
          (type list list)
   )
  (member e list 
     :test #'(lambda (e element) (equal element e))))

;************* substitute-one-condition (condition mapping)**********

(defun instantiate-list (list1 mapping)
  "Tw-routines/general.lsp
   if list1= (p $x $y i), mapping= (($x a) ($y b)) then return
   (p a b i)."
  (declare (list list1) (list mapping))

  (mapcar
   #'(lambda (list1-ele &aux binding)
       (if (setq binding (assoc list1-ele mapping))
	   (second binding)
	 list1-ele ))
   list1 )))

		   
(defun instantiate-all-lists (lists mapping)
  "Tw-routines/general.lsp
   if lists= ((p x y)...), mapping= ((x a) (y b)) then return
   ((p a b)....)"			   
  (declare (type list lists) (type list mapping))

  (mapcar #'(lambda (list1)
	      (instantiate-list list1 mapping) )
	  lists ))

;************************ clean-up mapping *********************

(defun clean-up-mapping (substitution-list old-variables)
  "Tw-routines/general.lsp
   if substitution-list= (($x a)($z u)), and 
   old-variables= ( $x a $z $w), then return (($x a) ($z $z') ($w $w'))."
   (declare (type list substitution-list) (type list old-variables))

   (setq substitution-list
	 (remove-all-var-pairs substitution-list) )
   (append
    substitution-list
    (mapcar #'(lambda (old-var)
		(list old-var (create-var)) )
	    (remove-if #'constant-p
		       (set-difference 
			old-variables
			(mapcar #'car substitution-list)
			:test #'equal ))))))

(defun remove-all-var-pairs (substitution-list)
  "Tw-routines/general.lsp
   if substitution-list= ((x a) (y b) (z u)), return ((x a) (y b)), 
   since the last one is a pair of variables"
  (declare (type list substitution-list))

  (remove-if
   #'(lambda (pair)
       (and (var-p (first pair))
	    (var-p (second pair)) ))
   substitution-list ))

			     
(defun create-var ()
  "Tw-routines/general.lsp
   create a variable"
  (gentemp "$"))


(defun create-opid ()
  "Tw-routines/general.lsp
