;; This fn should be called directly by the interface which prompts the
;;  user for I, G, and the required-opids.

(defun ordered-i-g-and-reqd-ops-triples (i g reqd-opids)
  (let* ((required-ops
	  (mapcar #'(lambda (reqd-opid)
		      (create-new-op-instance ;can be reused across combos
		       (find reqd-opid *operators*
			     :key #'operator-opid )))
		  required-opids ))
	 (required-ops-combos
	  (leg-combos-for-required-ops required-ops) )
	 (num-of-legs (length (car required-ops-combos))) ;all the same
	 (actor-group (second (second i))) ;other i's or g also okay
	 CPs-list ) ;this list can be reused for each combo attempt
    (dotimes (n (1- num-of-legs))
	     (push (gentemp "$cp") CPs-list) )
    (do* ((reqd-ops-combos1 required-ops-combos (cdr reqd-ops-combos1))
	  (sub-i-and-g-triples nil nil) )
	 ((null reqd-ops-combos1))
	 (do* ((reqd-ops-llist (car reqd-ops-combos1) (cdr reqd-ops-llist))
	       (goal-locs (reverse CPs-list) (cdr goal-locs))
	       (curr-loc 'dummy curr-loc)
	       (prior-loc 'dummy prior-loc)
	       (first-time? t nil)
	       (last-time? nil (null (cdr reqd-ops-llist))) )
	      ((null reqd-ops-llist))
	      (push (list*
		     (if first-time?
			 (second i)
		       `((at-location ,actor-group ,curr-loc) ;from Mfls
			 (moving-along-leg ,actor-group
					   ,prior-loc
					   ,curr-loc
					   ,(gentemp "$speed")
					   ,(gentemp "$security")
					   ,(gentemp "$method") )))
		     (if last-time?
			 (second g)
		       `((at-location ,actor-group ,(car goal-locs))) ) ;Mtle
		     (car reqd-ops-llist) )
		    sub-i-and-g-triples )
	      (setq prior-loc (if first-time? (first i) curr-loc)
		    curr-loc (car goal-locs) ))
	 (when
	  (every #'(lambda (i-and-g-triple)
		     (setq *solution* nil)
		     (plan (first i-and-g-triple)
			   (second i-and-g-triple)
			   :required-ops (cddr i-and-g-triple)
			   :subgoal-determine-mode 'closest-to-initial
			   :exist-est-heuristic 'diff-stage-nece-and-poss
			   )
		     *solution* )
		 sub-i-and-g-triples )
	  (return-from 'dummy ordered-i-g-and-reqd-ops-triples) ))))
;; Create a way of stitching the plans from diff legs together


(defun leg-combos-for-required-ops (ops)
  (disjoint-combinations (segregate-ops-by-stages ops)) )

(defun segregate-ops-by-stages (operators)
  (declare (list operators))

  (let ((stages-alist nil)
	op1-stage
	op1-alist )
    (dolist (op1 operators)
	    (setq op1-stage (operator-stage op1))
	    (cond ((null op1-stage) 'diddly)
		  ;; For the time being, we are not going to allow ops with
		  ;;  NIL stages (i.e. filter ops) to be part of a required
		  ;;  ops list.  It would confuse things.
		  ((setq op1-alist (assoc op1-stage stages-alist))
		   (push op1 (cdr op1-alist)) )
		  ((null op1-alist)
		   (push (list op1-stage op1)
			 stages-alist ))
		  (t 'diddly) ))
    (mapcar #'cdr stages-alist) )) ;strip off numerical index

;; I have lost the "leftover" reqd-ops here(v).  What I really want from
;;  ((a1 a2)(b1)) is ( ((a1 b1)(a2)) ((a1)(a2 b1)) )

;;((c1 c2 c3)) --> (((c1)(c2)(c3)))
;;((b1)(c1 c2 c3)) --> (((b1 c1)(c2)(c3)) ((c1)(b1 c2)(c3)) ((c1)(c2)(b1 c3)) )

(defun disjoint-combinations (sets1)
  (if sets1
      (if (cdr sets1)
	  (let* ((items1 (car sets1))
		 (disj-combos1 (disjoint-combinations (cdr sets1)))
		 (items-combos-len-diff
		  (- (length items1)
		     (length (car disj-combos1)) )) ;all the same
		 (filler-list (make-list (abs items-combos-len-diff)))
		 (items-permos
		  (if (<= 0 items-combos-len-diff)
		      (permutations items1)
		    (remove-duplicates
		     (permutations (append items1 filler-list))
		     :test #'equalp ))))
	    (when (< 0 items-combos-len-diff)
		  (setq disj-combos1
			(mapcar #'(lambda (disj-combo1)
				    (append disj-combo1 filler-list) )
				disj-combos1 )))
	    (mapcar
	     #'(lambda (items-permo1)
		 (apply
		  #'append
		  (mapcar #'(lambda (disj-combo1)
			      (mapcar #'(lambda (x y)
					  (if x
					      (cons x y)
					    y ))
				      items-permo1
				      disj-combo1 ))
			  disj-combos1 )))
	     items-permos ))
	(list (mapcar #'list (car sets1))) )
    (list nil) ))

(defun permutations (set1)
  (if set1
      (apply
       #'append
       (mapcar #'(lambda (item1)
		   (mapcar #'(lambda (permo1)
			       (cons item1 permo1) )
			   (permutations (remove item1 set1 :count 1)) ))
	       set1 ))
    (list nil) ))


#|
(defun combinations (set1)
  (if set1
      (let ((item1 (car set1))
	    (combos1 (combinations (cdr set1))) )
	(append combos1
		(mapcar #'(lambda (set2)
			    (cons item1 set2) )
			combos1 )))
    (list nil) ))

;;e.g. ((a1 a2)(b1 b2)(c1)) --> ((a1 b1 c1)(a2 b1 c1)(a1 b2 c1)(a2 b2 c1))
(defun disjoint-combinations2 (sets1)
  (if sets1
      (apply
       #'append
       (mapcar
	#'(lambda (disj-combo1)
	    (mapcar
	     #'(lambda (item1)
		 (cons item1 disj-combo1) )
	     (car sets1) ))
	(disjoint-combinations2 (cdr sets1)) ))
    (list nil) ))

(defun form-cp-pairs (CPs) ;e.g. (1 2 3 4) --> ((1 . 2)(2 . 3)(3 . 4))
  (and (cdr CPs)
       (let ((pair (cons (first CPs) (second CPs))))
	 (if (cddr CPs)
	     (cons pair
		   (form-cp-pairs (cdr CPs)) )
	   (list pair) ))))
