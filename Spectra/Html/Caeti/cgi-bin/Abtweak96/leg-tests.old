(defun test3 () ;for LEG 3
  (plan '(cp35
	  (STOPPED-AT WHITE cp35 $exec-time36) )
	'(cp24
	  (IN-STAT-FORMATION WHITE cp24 COIL $security43 $exec-speed44
			     $mo-speed45 $exec-time42))
	:subgoal-determine-mode 'closest-to-initial
	:exist-est-heuristic 'diff-stage-nece-and-poss
	:required-ops (create-requireds-list
		       '(MTLEfNBO NBD two tivf MOFsbo sicf) ) ;was 'tiwf
	:print-output-p t
	:plan-debug-mode t ))

(defun test4 () ;for LEG 2
  (plan '(cp25
	  (AT-LOCATION WHITE cp25 $exec-time31)
	  (MOVING-ALONG-LEG WHITE (390 175) cp25 $speed32
			    $security33 $method34))
	'(cp35
	  (STOPPED-AT WHITE cp35 $exec-time36) )
	:subgoal-determine-mode 'closest-to-initial
	:exist-est-heuristic 'diff-stage-nece-and-poss
	:required-ops (create-requireds-list
		       '(dapaa twbo MFLS) ) ;removed 'mtle-bo
	:print-output-p t
	:plan-debug-mode t ))

(defun test5 () ;for LEG 1
  (plan '((390 175)
	  (IN-STAT-FORMATION WHITE (390 175) HERRINGBONE $security26
			     $exec-speed27 $mo-speed28 0.0) )
	'(cp25
	  (AT-LOCATION WHITE cp25 $exec-time31)
	  (MOVING-ALONG-LEG WHITE (390 175) cp25 $speed32 $security33
			    $method34))
	:subgoal-determine-mode 'closest-to-initial
	:exist-est-heuristic 'diff-stage-nece-and-poss
	:required-ops (create-requireds-list
		       '(MTLEfNBO cwsafd ntm ticf MOFSF) )
	:print-output-p t
