	  (setq *mapdb-stream*
		(open mapdb-file 
		      :direction :output 
		      :if-exists :overwrite
		      :if-does-not-exist :create))
	  (write map :stream *mapdb-stream*)
	  (close *mapdb-stream*)
	  t)
      (progn
	(format *standard-output* "~&Warning - map database not overwritten!! ~&")
	nil))
  ))

(defun load-mapdb ()
" load previously saved updated mapdb array "
  (let (
	(mapdb-file "CaetiMapDB/caeti-mapdb-file1.dat")
	)
    (setq *mapdb* (read (open mapdb-file :direction :input)))
    ))

(defun update-map (map)
" in place update of map to include vector range and locality info "
  (let ( (x 180) (y 370) (xend 280) (yend 500) (old-thing nil) )
    (loop   ; x
     (setq y 370)
     (format *standard-output* "~&")
     (loop  ; y

      (setq old-thing (get-map-xy map x y))
      (set-map-xy map x y (list (first  old-thing)  ; x coord
				(second old-thing)  ; y coord
				(third  old-thing)  ; pt type 0 pln 1 fst 2 mtn
				(pt-range map x y)  ; width
				(second (range-calc map x y)))) ; compass ray szs

      (format *standard-output* "~A" (third old-thing))

      (setq y (1+ y))
      (if (= y yend) (return))
      )
     (setq x (1+ x))
     (if (= x xend) (return))
     )
    ))
