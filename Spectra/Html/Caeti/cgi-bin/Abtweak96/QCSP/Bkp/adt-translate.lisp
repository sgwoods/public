(defun var-not-defined (name type &optional (array nil))

  (if *debug* (progn
		(comment1 "var-not-defined: name = " name)
		(comment1 "                 type = " type)
		(comment1 "                 opt array = " array)))

  (if array
      (cond
       ((eq type 'int)
	(if (member name intAlist)
	    nil
	  (progn
	    (if *debug* (comment1 "Adding to intAlist = " name))
	    (setf intAlist (cons name intAlist))
	    t)	  ))
       ((eq type 'real)
	(if (member name realAlist)
	    nil
	  (progn
	    (if *debug* (comment1 "Adding to realAlist = " name))
	    (setf realAlist (cons name realAlist))
	    t) 	  ))
       ((eq type 'char)
	(if (member name charAlist)
	    nil
	  (progn
	    (if *debug* (comment1 "Adding to charAlist = " name))
	    (setf charAlist (cons name charAlist))
	    t) 	  ))
       ((eq type 'boolean)
	(if (member name boolAlist)
	    nil
	  (progn
	    (if *debug* (comment1 "Adding to boolAlist = " name))
	    (setf boolAlist (cons name boolAlist))
	    t) 	  ))
	)
    (cond  ;; not an array just a basic type
       ((eq type 'int)
	(if (member name intlist)
	    nil
	  (progn
	    (if *debug* (comment1 "Adding to intlist = " name))
	    (setf intlist (cons name intlist))
	    t) 	  ))
       ((eq type 'real)
	(if (member name reallist)
	    nil
	  (progn
	    (if *debug* (comment1 "Adding to reallist = " name))
	    (setf reallist (cons name reallist))
	    t) 	  ))
       ((eq type 'char)
	(if (member name charlist)
	    nil
	  (progn
	    (if *debug* (comment1 "Adding to charlist = " name))
	    (setf charlist (cons name charlist))
	    t) 	  ))
       ((eq type 'boolean)
	(if (member name boollist)
	    nil
	  (progn
	    (if *debug* (comment1 "Adding to boollist = " name))
	    (setf boollist (cons name boollist))
	    t) 	  ))
      ))
  ) ; defun close

(defun show-lists ()
  (comment "Intlist = ")  (show-list intlist) 
  (comment "Reallist = ") (show-list reallist) 
  (comment "Charlist = ") (show-list charlist) 
  (comment "Boollist = ") (show-list boollist) 
  (comment "IntAlist = ")  (show-list intAlist) 
  (comment "ReaAllist = ") (show-list realAlist) 
  (comment "CharAlist = ") (show-list charAlist) 
  (comment "BoolAlist = ") (show-list boolAlist) 
  )

(defun clear-closure ()
  (setq intlist '(firstInt))
  (setq charlist '(firstChar))
  (setq reallist '(firstReal))
  (setq boollist '(firstBool))
  (setq intAlist  '(firstarrayI))
  (setq charAlist '(firstarrayC))
  (setq realAlist '(firstarrayR))
  (setq boolAlist '(firstarrayB)) )


