(defun my-downcase (name)
    (if (null name)
      ""
    (if (listp name)
	(concatenate 'string (my-downcase (car name)) " " (my-downcase (cdr name)))
      (if (numberp name)
	  (num-to-string name)
	(fix-name (string-downcase name))))))

(defun fix-name (name)
  (let (
	(curpos 0)
	(endpos (length name))
	)
    (if (equal name "real")
	"float"
      (progn
	(loop
	 (if (= curpos endpos) (return))
	 (if (eq (char name curpos) #\-)
	     (setf (char name curpos) #\_))
	 (setq curpos (1+ curpos))
	 )
	name)) ))

(defun out-line (cprog-stream line)
  (format cprog-stream  line)    
  (format cprog-stream  "~1%")   
  )

(defun show-list ( list1 )
  (format *output-stream* "~& List ... ~&")
  (dolist (this list1)
	  (format *output-stream* "Element = ~A ~&" this))
  (format *output-stream* "~& End List. ~&"))

