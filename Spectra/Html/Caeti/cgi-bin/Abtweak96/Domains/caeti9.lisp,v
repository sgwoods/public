@;; Pautler CAETI 8 CHANGED Jun 21/97

;;***************************************************************************
;;*****                           CAETI operators                       *****
;;***************************************************************************

;; NOTE: Any change to the predicates used for operator-names, or any
;;  new ops, should be accompanied by updates to the op-name list
;;  in "caeti-demoX.lsp".

;;--------------------------------------------------------------------------
;; Move-out methods     STAGE 1
;;--------------------------------------------------------------------------

;; This would be used only for a change of trav formation or trav technique.
(setq mfls
      (make-operator
       :opid 'mfls
       :name '(Move-from-leg-start
	       $group $xy2 $xy3 $tform $method2 $exec-time $xy1 $method1
	       $security )
       :cost 1
       :stage 1
       :preconditions '(
			(at-location $group $xy2 $exec-time)
			(moving-along-leg $group $xy1 $xy2 $security $method1)

			(angle-formed $xy1 $xy2 $xy3 180.0)
			(move-order-given-to $group Move-Through $xy2
					     $tform $method2 )
			)
       :effects       '(
			(started-on-leg $group $xy2 $xy3 Move-through $tform
					$method2 $exec-time )
			(NOT moving-along-leg $group $xy1 $xy2 
			     $security $method1 )
			(NOT at-location $group $xy2 $exec-time)
			)))

;; This would be used for a change of direction, trav form, or trav techn.
(setq codd
      (make-operator
       :opid 'codd
       :name '(Change-of-direction-drill
	       $group $xy2 $xy3 $tform $method2 $exec-time $degrees $xy1
	       $method1 $security )
       :cost 2
       :stage 1
       :preconditions '(
			(at-location $group $xy2 $exec-time)
			(moving-along-leg $group $xy1 $xy2 $security $method1)

			(angle-formed $xy1 $xy2 $xy3 $degrees)
			(< 15.0   (absolute-value (- 180.0 $degrees))) ;no U's
			(minimize (absolute-value (- 180.0 $degrees)))
			(change-of-direction-order-given-to $group $degrees
							    $xy2
							    $tform $method2 )
			)
       :effects       '(
			(started-on-leg $group $xy2 $xy3 $degrees $tform
					$method2 $exec-time )
			(NOT moving-along-leg $group $xy1 $xy2 
			     $security $method1 )
			(NOT at-location $group $xy2 $exec-time)
			)))

(setq codtae
      (make-operator
       :opid 'codtae
       :name '(Change-of-direction-to-assault-enemy
	       $group $xy2 $xy3 $xy4 $method2 $exec-time $degrees
	       $t-time $firing-or-not $xy1 $method1 $security )
       :cost 2
       :stage 1
       :preconditions '(
			(at-location $group $xy2 $exec-time)
			(moving-along-leg $group $xy1 $xy2 $security $method1)

			(angle-formed $xy1 $xy2 $xy3 $degrees)
			(< 15.0   (absolute-value (- 180.0 $degrees))) ;no U's
			(minimize (absolute-value (- 180.0 $degrees)))
			(change-of-direction-order-given-to $group $degrees
							    $xy2
							    Line $method2 )
			(collective-travel-time $xy2 $xy3 $t-time)
			(separation $xy3 $xy4 0.2 0.4)
			(< (distance-between $xy2 $xy3)
			   (distance-between $xy2 $xy4) )
			(angle-formed $xy2 $xy3 $xy4 180.0)
			(leg-clear $xy3 $xy4)
			(enemy-unit (options Artillery T-72s BMPs) $xy4 $xy2
				    Not-moving $firing-or-not
				    (+ $exec-time $t-time) )
			(fire-order-given-to $group $xy4 $xy3)
			)
       :effects       '(
			(started-on-leg $group $xy2 $xy3 $degrees Line
					$method2 $exec-time )
			(NOT moving-along-leg $group $xy1 $xy2 
			     $security $method1 )
			(NOT at-location $group $xy2 $exec-time)
			)))

(setq codtao
      (make-operator
       :opid 'codtao
       :name '(Change-of-direction-to-avoid-obstacle
	       $group $xy2 $xy3 $xy4 $xy5 $tform $method2 $exec-time
	       $degrees1 $degrees2 $xy1 $method1 $security $foo )
       :cost 2
       :stage 1
       :preconditions '(
			(at-location $group $xy2 $exec-time)
			(moving-along-leg $group $xy1 $xy2 $security $method1)

			(angle-formed $xy1 $xy2 $xy3 180.0)
			;;v how big is the obstacle?
			(terrain-type $xy2 (options Plain Forest) $foo)
			(obstacle (options Minefield Wire) $xy2 $exec-time)
			(separation $xy2 $xy4 0.2 2.0)
			(angle-formed $xy1 $xy2 $xy4 $degrees1)
			(< 30.0 (absolute-value (- 180.0 $degrees1)))
			(< (absolute-value (- 180.0 $degrees1)) 90.0)
			(leg-clear $xy2 $xy4)

			(separation $xy4 $xy5 0.2 2.0)
			(angle-formed $xy2 $xy4 $xy5 $degrees2)
			(< 30.0 (absolute-value (- 180.0 $degrees2)))
			(< (absolute-value (- 180.0 $degrees2)) 90.0)
			(leg-clear $xy4 $xy5)
			(angle-formed $xy1 $xy2 $xy5 180.0)
			(< (distance-between $xy2 $xy5)
			   (distance-between $xy2 $xy3) )
			)
       :effects       '(
			(started-on-leg $group $xy2 $xy3 Move-Through $tform
					$method2 $exec-time )
			(NOT moving-along-leg $group $xy1 $xy2 
			     $security $method1 )
			(NOT at-location $group $xy2 $exec-time)
			)))

(setq codtaia
      (make-operator
       :opid 'codtaia
       :name '(Change-of-direction-to-avoid-impact-area
	       $group $xy2 $xy3 $xy4 $xy5 $xy6 $tform $method2 $exec-time
	       $degrees1 $degrees2 $moving-or-not $foo $xy1 $method1
	       $security )
       :cost 2
       :stage 1
       :preconditions '(
			(at-location $group $xy2 $exec-time)
			(moving-along-leg $group $xy1 $xy2 $security $method1)

			(angle-formed $xy1 $xy2 $xy3 180.0)
			(terrain-type $xy6 (options Plain Forest) $foo)
			;;v how big is the obstacle?
			(enemy-unit (options Artillery T-72s) $xy6 $xy2
				    $moving-or-not Firing $exec-time )
			(separation $xy2 $xy6 0.1 1.0) ;in firing range
			(separation $xy2 $xy4 0.2 2.0)
			(angle-formed $xy1 $xy2 $xy4 $degrees1)
			(< 30.0 (absolute-value (- 180.0 $degrees1)))
			(< (absolute-value (- 180.0 $degrees1)) 90.0)
			(leg-clear $xy2 $xy4)

			(separation $xy4 $xy5 0.2 2.0)
			(angle-formed $xy2 $xy4 $xy5 $degrees2)
			(< 30.0 (absolute-value (- 180.0 $degrees2)))
			(< (absolute-value (- 180.0 $degrees2)) 90.0)
			(leg-clear $xy4 $xy5)
			(angle-formed $xy1 $xy2 $xy5 180.0)
			(< (distance-between $xy2 $xy5)
			   (distance-between $xy2 $xy3) )
			)
       :effects       '(
			(started-on-leg $group $xy2 $xy3 Move-Through $tform
					$method2 $exec-time )
			(NOT moving-along-leg $group $xy1 $xy2 
			     $security $method1 )
			(NOT at-location $group $xy2 $exec-time)
			)))

(setq mofsf
      (make-operator
       :opid 'mofsf
       :name '(Move-out-from-stationary-formation
	       $group $xy1 $xy2 $tform $method $exec-time $pos $moving-or-not
	       $sform $security )
       :cost 3  ;Pref should lean toward Mfls or Action-drills because most
       :stage 1 ; legs will be in the middle of a route/plan.
       :preconditions '(
			(in-stat-formation $group $xy1 $sform $security
					   $exec-time )

			(NOT-enemy-unit (options Helicopter Artillery
						 T-72s BMPs )
			     $pos $xy1 $moving-or-not Firing $exec-time )
			(leg-clear $xy1 $xy2)
			(move-order-given-to
			 $group Move-From $xy1 $tform $method )
			)
       :effects       '(
			(started-on-leg $group $xy1 $xy2
					Move-From $tform $method
					(+ $exec-time
					   (if (= Coil $sform)
					       0.2
					     0.1 ))) ;Herringbone
			(NOT in-stat-formation $group $xy1 $sform $security
			     $exec-time )
			)))

(setq mofhtf
      (make-operator
       :opid 'mofhtf
       :name '(Move-out-from-halted-traveling-formation
	       $group $xy2 $xy3 $tform2 $method2 $exec-time $pos $moving-or-not
	       $xy1 $tform1 $method1 $fire-f $fire-l $fire-r )
       :cost 4
       :stage 1
       :preconditions '(
			(stopped-at $group $xy2 $exec-time)
			(in-trav-formation $group $xy1 $xy2 $tform1
					   $fire-f $fire-l $fire-r $method1 )

			(NOT-enemy-unit (options Helicopter Artillery
						 T-72s BMPs )
			     $pos $xy2 $moving-or-not Firing $exec-time )
			(leg-clear $xy2 $xy3)
			(move-order-given-to
			 $group Move-From $xy2 $tform2 $method2 )
			)
       :effects       '(
			(started-on-leg $group $xy2 $xy3
					Move-From $tform2 $method2
					(+ $exec-time 0.05) )
			(NOT in-trav-formation $group $xy1 $xy2 $tform1
			     $fire-f $fire-l $fire-r $method1 )
			(NOT stopped-at $group $xy2 $exec-time)
			)))

(setq mofsbo
      (make-operator
       :opid 'mofsbo
       :name '(Move-out-from-stopped-bounding-overwatch
	       $group $xy2 $xy3 $tform $method $exec-time $pos $moving-or-not )
       :cost 5
       :stage 1
       :preconditions '(
			(stopped-at $group $xy2 $exec-time)
			;;doesn't have 'in-trav' precond of MOFHTF

			(NOT-enemy-unit (options Helicopter Artillery
						 T-72s BMPs )
			     $pos $xy2 $moving-or-not Firing $exec-time )
			(leg-clear $xy2 $xy3)
			(move-order-given-to
			 $group Move-From $xy2 $tform $method )
			)
       :effects       '(
			(started-on-leg $group $xy2 $xy3
					Move-From $tform $method
					(+ $exec-time 0.05) )
			(NOT stopped-at $group $xy2 $exec-time)
			)))

(setq rtifd-sf
      (make-operator
       :opid 'rtifd-sf
       :name '(React-to-indirect-fire-drill-Stat-form
	       $group $xy1 $xy2 $tform $method $exec-time $pos $moving-or-not
	       $foo $sform $security )
       :cost 5 ;Pref should lean toward Mofsf
       :stage 1
       :preconditions '(
			(in-stat-formation $group $xy1 $sform $security
					   $exec-time )

			(terrain-type $pos (options Plain Forest) $foo)
			(enemy-unit (options Artillery T-72s BMPs)
				    $pos $xy1 $moving-or-not Firing
				    $exec-time )
			(leg-clear $xy1 $xy2)
			(move-order-given-to
			 $group Move-From $xy1 $tform $method )
			)
       :effects       '(
			(started-on-leg $group $xy1 $xy2
					Move-From $tform $method
					(+ $exec-time
					   (if (= Coil $sform)
					       0.2
					     0.1 ))) ;Herringbone
			(NOT in-stat-formation $group $xy1 $sform $security
			     $exec-time )
			)))
;;Plt Evaluation: should not execute when engaged in direct fire or when
;; ordered to remain stationary.

(setq rtifd-htf
      (make-operator
       :opid 'rtifd-htf
       :name '(React-to-indirect-fire-drill-Halted-traveling-formation
	       $group $xy2 $xy3 $tform2 $method2 $exec-time $pos $moving-or-not
	       $foo $xy1 $tform1 $method1 $fire-f $fire-l $fire-r )
       :cost 5
       :stage 1
       :preconditions '(
			(stopped-at $group $xy2 $exec-time)
			(in-trav-formation $group $xy1 $xy2 $tform1
					   $fire-f $fire-l $fire-r $method1 )

			(terrain-type $pos (options Plain Forest) $foo)
			(enemy-unit (options Artillery T-72s BMPs)
				    $pos $xy1 $moving-or-not Firing
				    $exec-time )
			(leg-clear $xy2 $xy3)
			(move-order-given-to
			 $group Move-From $xy2 $tform2 $method2 )
			)
       :effects       '(
			(started-on-leg $group $xy2 $xy3
					Move-From $tform2 $method2
					(+ $exec-time 0.05) )
			(NOT in-trav-formation $group $xy1 $xy2 $tform1
			     $fire-f $fire-l $fire-r $method1 )
			(NOT stopped-at $group $xy2 $exec-time)
			)))

(setq rtifd-sbo
      (make-operator
       :opid 'rtifd-sbo
       :name '(React-to-indirect-fire-drill-Stopped-bounding-overwatch
	       $group $xy2 $xy3 $tform2 $method2 $exec-time $pos $moving-or-not
	       $foo $xy1 )
       :cost 5
       :stage 1
       :preconditions '(
			(stopped-at $group $xy2 $exec-time)
			;; assume in bounding overwatch

			(terrain-type $pos (options Plain Forest) $foo)
			(enemy-unit (options Artillery T-72s BMPs)
				    $pos $xy1 $moving-or-not Firing
				    $exec-time )
			(leg-clear $xy2 $xy3)
			(move-order-given-to
			 $group Move-From $xy2 $tform2 $method2 )
			)
       :effects       '(
			(started-on-leg $group $xy2 $xy3
					Move-From $tform2 $method2
					(+ $exec-time 0.05) )
			(NOT stopped-at $group $xy2 $exec-time)
			)))

;;--------------------------------------------------------------------------
;; Traveling formations     STAGE 2
;;--------------------------------------------------------------------------
;;
;; Troops prefer wedges to staggered columns, which they prefer to columns;
;; so, staggered columns and columns are made more expensive here.  I assume
;; that echelons, lines, and vees are comparable to staggered columns.

(setq tiwf ;;This is only the 'wedge-left' version, in which the left flank
      (make-operator                                ; is longer
       :opid 'tiwf
       :name '(Travel-in-wedge-formation
	       $group1 $movement $xy1 $xy2 $method $group2 $exec-time )
       :cost 1
       :stage 2
       :preconditions '(
			(started-on-leg $group1 $xy1 $xy2 $movement Wedge
					$method $exec-time )

			(leg-lateral-space $xy1 $xy2 (range 0.4 pos-infin))
			(overwatching $group2 $group1 $xy1 $xy2)
			)
       :effects       '(
			(in-trav-formation $group1 $xy1 $xy2 Wedge
					   Fire-excellent Fire-good
					   Fire-moderate $method )
			)))
;;Plt Evalution: Maintaining proper following distance and formation depth?

(setq tiscf
      (make-operator
       :opid 'tiscf
       :name '(Travel-in-staggered-column-formation
	       $group $movement $xy1 $xy2 $method $exec-time )
       :cost 2
       :stage 2
       :preconditions '(
			(started-on-leg $group $xy1 $xy2 $movement
					Staggered-column $method $exec-time )

			(leg-lateral-space $xy1 $xy2 (range 0.2 pos-infin))
			)
       :effects       '(
			(in-trav-formation $group $xy1 $xy2 Staggered-column
					   Fire-good Fire-good
					   Fire-good $method )
			)))
(setq tief ;;This is only the 'echelon-left' version, in which there is no
      (make-operator                                   ; right flank defense
       :opid 'tief
       :name '(Travel-in-echelon-formation
	       $group $movement $xy1 $xy2 $method $exec-time )
       :cost 2
       :stage 2
       :preconditions '(
			(started-on-leg $group $xy1 $xy2 $movement Echelon
					$method $exec-time )

			(leg-lateral-space $xy1 $xy2 (range 0.4 pos-infin))
			)
       :effects       '(
			(in-trav-formation $group $xy1 $xy2 Echelon
					   Fire-excellent Fire-excellent
					   Fire-bad $method )
			)))
(setq tivf
      (make-operator
       :opid 'tivf
       :name '(Travel-in-vee-formation
	       $group $movement $xy1 $xy2 $method $exec-time )
       :cost 2
       :stage 2
       :preconditions '(
			(started-on-leg $group $xy1 $xy2
					$movement Vee $method $exec-time )

			(leg-lateral-space $xy1 $xy2 (range 0.4 pos-infin))
			)
       :effects       '(
			(in-trav-formation $group $xy1 $xy2 Vee
					   Fire-moderate Fire-good
					   Fire-good $method )
			)))
(setq tilf
      (make-operator
       :opid 'tilf
       :name '(Travel-in-line-formation
	       $group1 $movement $xy1 $xy2 $method $group2 $exec-time )
       :cost 2
       :stage 2
       :preconditions '(
			(started-on-leg $group1 $xy1 $xy2
					$movement Line $method $exec-time )

			(leg-lateral-space $xy1 $xy2 (range 0.4 pos-infin))
			(overwatching $group2 $group1 $xy1 $xy2)
			)
       :effects       '(
			(in-trav-formation $group1 $xy1 $xy2 Line
					   Fire-excellent Fire-bad
					   Fire-bad $method )
			)))
(setq ticf
      (make-operator
       :opid 'ticf
       :name '(Travel-in-column-formation
	       $group $movement $xy1 $xy2 $method $exec-time )
       :cost 3
       :stage 2
       :preconditions '(
			(started-on-leg $group $xy1 $xy2
					$movement Column $method $exec-time )

			(leg-lateral-space $xy1 $xy2 (range 0.1 pos-infin))
			)
       :effects       '(
			(in-trav-formation $group $xy1 $xy2 Column
					   Fire-moderate Fire-moderate
					   Fire-moderate $method )
			)))

;;--------------------------------------------------------------------------
;; Traveling methods     STAGE 3
;;--------------------------------------------------------------------------

(setq ntm
      (make-operator
       :opid 'ntm
       :name '(Normal-travel-method
	       $group $movement $xy1 $xy2 $tform $exec-time $ff $fl $fr )
       :cost 1
       :stage 3
       :preconditions '(
			(started-on-leg $group $xy1 $xy2 $movement $tform
					Normal-travel-method $exec-time )
			(in-trav-formation $group $xy1 $xy2 $tform
					   $ff $fl $fr Normal-travel-method )

			(separation $xy1 $xy2 1.0 pos-infin) ;minimum distance
			(leg-clear $xy1 $xy2)
			)
       :effects       '(
			(moving-along-leg $group $xy1 $xy2 Security-moderate
					  Normal-travel-method )
			(NOT started-on-leg $group $xy1 $xy2
			     $movement $tform Normal-travel-method $exec-time )

			(ready-for-drill $group $xy1 $xy2 $exec-time 1.0)
			)))

;; The only kinds of traveling formations used with the traveling overwatch
;;  in the training tables are staggered column and vee.  We do not know
;;  if those two are more appropriate for traveling overwatches than others
;;  or why.
(setq two
      (make-operator
       :opid 'two
       :name '(Travel-with-overwatch
	       $group $movement $xy1 $xy2 $tform $exec-time )
       :cost 6 ;=TT + col + mfls + 1 ;consider only after TT leg tried
       :stage 3
       :preconditions '(
			(started-on-leg $group $xy1 $xy2 $movement $tform
					Travel-with-overwatch $exec-time )
			(in-trav-formation $group $xy1 $xy2 $tform
					   (options Fire-moderate Fire-good
						    Fire-excellent ) 
					   Fire-good Fire-good
					   Travel-with-overwatch )

			(separation $xy1 $xy2 1.0 pos-infin) ;minimum distance
			(leg-clear $xy1 $xy2)
			)
       :effects       '(
			(moving-along-leg $group $xy1 $xy2 Security-good
					  Travel-with-overwatch )
			(NOT started-on-leg $group $xy1 $xy2 $movement
			     $tform Travel-with-overwatch $exec-time )

			(ready-for-drill $group $xy1 $xy2 $exec-time 1.75)
			)))

;; Bounding overwatches do not use traveling formations. -DHarper
;; The platoon leader chooses which kind of bounding overwatch to use
;;  (alternating or successive), not the CoCmdr. -DHarper

(setq twbo
      (make-operator
       :opid 'twbo
       :name '(Travel-with-bounding-overwatch
	       $group $movement $xy1 $xy2 $exec-time )
       :cost 11 ;= totm + col + mfls + 1 ;consider only after TT/totm leg tried
       :stage 3
       :preconditions '(
			(started-on-leg $group $xy1 $xy2 $movement
					No-traveling-formation
					Travel-with-bounding-overwatch
					$exec-time )

			(separation $xy1 $xy2 1.0 pos-infin) ;minimum distance
			(leg-lateral-space $xy1 $xy2 (range 0.4 pos-infin))
			(leg-clear $xy1 $xy2)
			)
       :effects       '(
			(moving-along-leg $group $xy1 $xy2 Security-excellent
					  Travel-with-bounding-overwatch )
			(NOT started-on-leg $group $xy1 $xy2
			     $movement No-traveling-formation
			     Travel-with-bounding-overwatch $exec-time )

			(ready-for-drill $group $xy1 $xy2 $exec-time 2.5)
			)))
;; The same security or better should be possible by traveling along a ridge
;;  which separates you from the enemy.
;; Identical to normal-travel, except distance is longer and plt will be
;;  evaluated on whether it buttoned up and observed heightened security
;;  measures.
(setq trm
      (make-operator
       :opid 'trm
       :name '(Tactical-road-march
	       $group $movement $xy1 $xy2 $tform $exec-time $ff $fl $fr )
       :cost 2
       :stage 3
       :preconditions '(
			(started-on-leg $group $xy1 $xy2 $movement $tform
					Tactical-road-march $exec-time )
			(in-trav-formation $group $xy1 $xy2 $tform
					   $ff $fl $fr Tactical-road-march )

			(separation $xy1 $xy2 3.0 pos-infin) ;minimum distance
			(leg-clear $xy1 $xy2)
			)
       :effects       '(
			(moving-along-leg $group $xy1 $xy2 Security-moderate
					  Tactical-road-march )
			(NOT started-on-leg $group $xy1 $xy2
			     $movement $tform Tactical-road-march $exec-time )

			(ready-for-drill $group $xy1 $xy2 $exec-time 1.0)
			)))

;;--------------------------------------------------------------------------
;; Battle Drills             STAGE 4
;;--------------------------------------------------------------------------

(setq nbd
      (make-operator
       :opid 'nbd
       :name '(No-battle-drill $group $xy1 $xy2 $exec-time $tt-multiplier)
       :cost 1 ;must have some cost, so reqd ops can cost less
       :stage 4
       :preconditions '(
			(ready-for-drill $group $xy1 $xy2 $exec-time
					 $tt-multiplier )
			)
       :effects       '(
			(drill-scheduled $exec-time $tt-multiplier)
			(NOT ready-for-drill $group $xy1 $xy2 $exec-time
			                     $tt-multiplier )
			)))

(setq plbeu ;This is just a way of making battlegrounds seem less empty
      (make-operator
       :opid 'plbeu
