/originalCTM matrix currentmatrix def

Begin %I Text
%I cfg Black
0 0 0 SetCFg
%I f *-helvetica-medium-r-*-140-*
Helvetica 14 SetF
%I t
[ 1 0 0 1 8.00001 1085 ] concat
%I
[
(Class String  {)
( char localStr [MAXSIZE];)
()
( String\( char* inStr \))
( {)
(   for \(int j=0; inStr[j]; j++\))
(       localStr[j] = inStr[j]; } )
()
( printString\(\))
( {)
(  for \(int j=0; localStr[j]; j++\))
(      printf\("%s",localStr[j]\); }   })
] Text
End

End %I eop

