      case 's':
      case 'S':
         scanf("%lf", &amount);
         printf("Service charge is %.2f\n", amount);
         balance -= amount;
         charges++;
         total_charges += amount;
         break;
      case 'w':
      case 'W':
         scanf("%lf", &amount);
         printf("Withdrawal is %.2f\n", amount);
         balance -= amount;
         withdrawals++;
         total_withdrawals += amount;
         break;
      default: 
         printf("Bad code: %c\n", c);
         break;
    }
   
    /* HERE IS THE CHANGE.

       This now has to skip characters until it hits the newline */

    c = getchar();   
    while (c != '\n')
      c = getchar();
