 * of space in the array.  We just quietly stop reading if we run out
 * of space.
 *
 * This version is the most concise version.
 */
#include <stdio.h>

int fill_array(int a[], int n)
{
  int count;
  int value;
  
  for (count = 0; scanf("%i", &value) == 1 && count < n; count++)
    a[count] = value;
  return count;
}
