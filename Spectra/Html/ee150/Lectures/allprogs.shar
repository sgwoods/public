         break;
      case 'c':
         printf("Check\n");
         break;
      case 'd':
         printf("Deposit\n");
         break;
      case 's':
         printf("Service charge\n");
         break;
      case 'w':
         printf("Withdrawal\n");
         break;
      default: 
